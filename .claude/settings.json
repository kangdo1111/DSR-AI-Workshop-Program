{
  "agents": {
    "enabled": true,
    "teams": [
      {
        "name": "news-analysis-team",
        "type": "coordinator",
        "description": "뉴스 자동화 시스템의 조정 팀",
        "coordinator": {
          "name": "메인 뉴스 분석기",
          "role": "조정자",
          "responsibility": "뉴스 수집 → 분석 흐름 관리, 전문가들에게 작업 위임"
        },
        "specialists": [
          {
            "id": "security-validator",
            "name": "보안 검증 에이전트",
            "role": "전문가",
            "responsibility": "RSS 피드 URL 검증, 데이터 무결성 확인",
            "tools": ["web_search", "bash", "read", "write"]
          },
          {
            "id": "performance-analyzer",
            "name": "성능 분석 에이전트",
            "role": "전문가",
            "responsibility": "수집 속도, AI 응답 시간 분석",
            "tools": ["code_execution", "read"]
          },
          {
            "id": "content-validator",
            "name": "콘텐츠 검증 에이전트",
            "role": "전문가",
            "responsibility": "뉴스 관련성, 요약 품질 검증",
            "tools": ["read", "write"]
          }
        ],
        "shared_workspace": "/workspace/data",
        "communication": {
          "type": "message_based",
          "coordinator_receives": ["validation_results", "performance_metrics", "quality_scores"],
          "specialist_receives": ["analysis_tasks", "data_segments"]
        }
      }
    ]
  },
  "version": "1.0",
  "created_at": "2026-06-12",
  "enabled_features": [
    "agent-teams",
    "managed-agents",
    "multiagent-coordination",
    "parallel-processing"
  ]
}
